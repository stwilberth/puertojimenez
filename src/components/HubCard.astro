---
import { Icon } from 'astro-icon/components';

interface Props {
    href: string;
    title: string;
    description: string;
    icon: string;
    iconColor: string;
    icon2?: string;
    icon2Color?: string;
    hoverTitle: string;
    gradient: string;
    cta?: string;
    featured?: boolean;
    class?: string;
}

const {
    href,
    title,
    description,
    icon,
    iconColor,
    icon2,
    icon2Color = 'text-slate-500',
    hoverTitle,
    gradient,
    cta,
    featured = false,
    class: className = '',
} = Astro.props;
---

<a href={href} class:list={['group block', className]}>
    <div class="relative h-full bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 dark:border-slate-800">
        <div class:list={['absolute inset-0 bg-gradient-to-br group-hover:opacity-100 transition-opacity', gradient]}></div>
        <div class="p-6 md:p-8 flex flex-col h-full relative z-10">
            <div class="flex items-center gap-4 mb-4">
                <div class="flex items-center gap-3">
                    <div class:list={[iconColor, 'group-hover:scale-110 transition-transform duration-500']}>
                        <Icon name={icon} class:list={[featured ? 'w-12 h-12 md:w-16 md:h-16' : 'w-10 h-10']} />
                    </div>
                    {icon2 && (
                        <div class:list={[icon2Color, 'group-hover:scale-110 transition-transform duration-500']}>
                            <Icon name={icon2} class:list={[featured ? 'w-12 h-12 md:w-16 md:h-16' : 'w-10 h-10']} />
                        </div>
                    )}
                </div>
                <h2 class:list={['text-xl md:text-2xl font-black text-slate-900 dark:text-white transition-colors', hoverTitle]}>
                    {title}
                </h2>
            </div>
            <p class:list={['text-slate-600 dark:text-slate-400', featured ? 'text-lg md:text-xl' : 'text-base']}>
                {description}
            </p>
            {cta && (
                <div class="mt-auto pt-10">
                    <span class:list={['inline-flex items-center font-bold tracking-widest uppercase text-sm', iconColor]}>
                        {cta}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                    </span>
                </div>
            )}
        </div>
    </div>
</a>
