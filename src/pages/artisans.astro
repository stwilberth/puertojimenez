---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ContainerFluid from '../components/ContainerFluid.astro';
import CallToAction from '../components/CallToAction.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const artists = await getCollection('artists');
---

<Layout title="Local Artisans & Artists - Puerto Jiménez">
    <main class="bg-gray-50 dark:bg-gray-900 min-h-screen">
        <Nav />
        <ContainerFluid>
            <section class="max-w-6xl mx-auto py-12 px-4">
                <div class="text-center mb-16">
                    <h1 class="text-5xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight">
                        Local Artisans & Artists <span class="text-orange-500">🎨</span>
                    </h1>
                    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
                        Discover the creative heartbeat of Puerto Jiménez. Our local artists transform the essence of the Osa Peninsula into unique masterpieces.
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
                    {artists.map((artist) => (
                        <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-xl overflow-hidden group hover:shadow-2xl transition-all duration-300 flex flex-col">
                            <div class="relative h-80 overflow-hidden">
                                {artist.data.image && (
                                    <Image 
                                        src={artist.data.image} 
                                        alt={artist.data.name}
                                        width={800}
                                        height={600}
                                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                                    />
                                )}
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-8">
                                    <div>
                                        <h2 class="text-3xl font-bold text-white mb-1">{artist.data.name}</h2>
                                        <div class="flex flex-wrap gap-2">
                                            {artist.data.specialty.map(spec => (
                                                <span class="px-3 py-1 bg-orange-500 text-white text-xs font-semibold rounded-full uppercase tracking-wider">
                                                    {spec}
                                                </span>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="p-8 flex-grow flex flex-col">
                                <p class="text-gray-600 dark:text-gray-300 mb-6 text-lg italic">
                                    "{artist.data.description}"
                                </p>
                                
                                <div class="space-y-4 mb-8">
                                    <div class="flex items-center text-gray-700 dark:text-gray-400">
                                        <span class="w-8 h-8 flex items-center justify-center bg-gray-100 dark:bg-gray-700 rounded-lg mr-3">🕒</span>
                                        <span class="font-medium">{artist.data.experience}</span>
                                    </div>
                                    {artist.data.email && (
                                        <div class="flex items-center text-gray-700 dark:text-gray-400">
                                            <span class="w-8 h-8 flex items-center justify-center bg-gray-100 dark:bg-gray-700 rounded-lg mr-3">✉️</span>
                                            <a href={`mailto:${artist.data.email}`} class="hover:text-orange-500 transition-colors">
                                                {artist.data.email}
                                            </a>
                                        </div>
                                    )}
                                </div>

                                {artist.data.productsImage && (
                                        <div class="mt-auto">
                                            <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">Work Showcase</p>
                                            <div class="rounded-2xl overflow-hidden h-48 border-4 border-gray-100 dark:border-gray-700">
                                            <Image 
                                                src={artist.data.productsImage} 
                                                alt={`${artist.data.name}'s work`}
                                                width={600}
                                                height={400}
                                                class="w-full h-full object-cover"
                                            />
                                            </div>
                                        </div>
                                    )}
                            </div>
                        </div>
                    ))}
                </div>

                <CallToAction 
                    title="Support Local Talent"
                    description="Interested in a custom piece or visiting a studio? We can help you connect with these amazing creators."
                    buttonText="Get in Touch"
                />
            </section>
        </ContainerFluid>
    </main>
</Layout>

<style>
    .tracking-tight { letter-spacing: -0.025em; }
</style>
