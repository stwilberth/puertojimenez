                    <div class="space-y-4 text-gray-700 dark:text-gray-300">
                        <div class="flex items-center space-x-3">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚕</span>
                            <span>Take a taxi to Tracopa Bus Terminal ($12)</span>
                            <a href="https://maps.app.goo.gl/s5wDXUJWoHchgoRq6"
                            target="_blank"
                            rel="noopener noreferrer">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                                View on Map
                            </span>
                        </a>
                        </div>
                        <div class="flex items-center space-x-3">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚌</span>
                            <span>Take a bus to Golfito or Río Claro ($17). Some buses go all the way to Golfito, but others only pass through Río Claro.</span>
                        </div>
                        <div class="mt-6 grid md:grid-cols-2 gap-6">
                            <!-- To Golfito -->
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
                                <h4 class="font-semibold text-gray-800 dark:text-white mb-3">San José → Golfito</h4>
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-200 dark:border-gray-600">
                                            <th class="pb-2 font-medium">Time</th>
                                            <th class="pb-2 font-medium">Route</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-gray-600">
                                        <tr><td class="py-2 font-mono">6:30 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">7:00 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Cerro de la Muerte</td></tr>
                                        <tr><td class="py-2 font-mono">3:30 pm</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">10:10 pm</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            <!-- To Río Claro -->
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
                                <h4 class="font-semibold text-gray-800 dark:text-white mb-3">San José → Río Claro</h4>
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-200 dark:border-gray-600">
                                            <th class="pb-2 font-medium">Time</th>
                                            <th class="pb-2 font-medium">Route</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-gray-600">
                                        <tr><td class="py-2 font-mono">5:00 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Cerro de la Muerte</td></tr>
                                        <tr><td class="py-2 font-mono">5:30 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">6:30 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">7:00 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Cerro de la Muerte</td></tr>
                                        <tr><td class="py-2 font-mono">7:31 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">7:40 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Cerro de la Muerte</td></tr>
                                        <tr><td class="py-2 font-mono">10:00 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Cerro de la Muerte</td></tr>
                                        <tr><td class="py-2 font-mono">10:15 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">11:00 am</td><td class="py-2 text-gray-600 dark:text-gray-300">Costanera</td></tr>
                                        <tr><td class="py-2 font-mono">1:00 pm</td><td class="py-2 text-gray-600 dark:text-gray-300">Cerro de la Muerte</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </ContainerFluid>

        <!-- Step 3: Final Leg -->
        <ContainerFluid>
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 mb-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                        <span class="text-2xl">3</span>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Final Leg - Boat Service</h2>
                </div>
                <div class="space-y-4 text-gray-700 dark:text-gray-300">
                    <div class="flex items-center space-x-3">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚌</span>
                        <span>From Rio Claro, take a bus to Golfito on coastal service ($3)</span>
                        <a href="https://maps.app.goo.gl/aboFMSXPDV3cRQ8y7"
                        target="_blank"
                        rel="noopener noreferrer">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                            View on Map
                        </span>
                    </a>
                    </div>
                    <div class="flex items-center space-x-3">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">⛴️</span>
                        <span>Take the boat to <button class="text-blue-600 dark:text-blue-400 underline hover:text-blue-800 dark:hover:text-blue-300 font-medium" onclick="openMapModal('Puerto Jiménez', 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14282.372962386315!2d-83.3125448602757!3d8.534870134331438!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa466c2a75032fb%3A0x8d5d454d2acd0d0!2sProvincia%20de%20Puntarenas%2C%20Puerto%20Jim%C3%A9nez!5e1!3m2!1ses!2scr!4v1741098876100!5m2!1ses!2scr')">Puerto Jiménez</button> ($19)</span>
                    </div>
                    <div class="mt-6">
                        <h4 class="font-semibold text-gray-800 dark:text-white mb-3">Boat Schedule — Muelle Municipal (Golfito → Puerto Jiménez)</h4>
                        <div class="grid md:grid-cols-3 gap-4">
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
                                <p class="text-xs font-bold text-green-600 dark:text-green-400 uppercase tracking-widest mb-2">Mon – Fri</p>
                                <ul class="space-y-1 text-sm font-mono text-gray-700 dark:text-gray-300">
                                    <li>7:00 am</li>
                                    <li>10:00 am</li>
                                    <li>1:00 pm</li>
                                    <li>4:30 pm</li>
                                </ul>
                            </div>
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
                                <p class="text-xs font-bold text-green-600 dark:text-green-400 uppercase tracking-widest mb-2">Saturday</p>
                                <ul class="space-y-1 text-sm font-mono text-gray-700 dark:text-gray-300">
                                    <li>8:00 am</li>
                                    <li>11:00 am</li>
                                    <li>3:00 pm</li>
                                </ul>
                            </div>
                            <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4">
                                <p class="text-xs font-bold text-green-600 dark:text-green-400 uppercase tracking-widest mb-2">Sunday</p>
                                <ul class="space-y-1 text-sm font-mono text-gray-700 dark:text-gray-300">
                                    <li>10:00 am</li>
                                    <li>3:00 pm</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="mt-8">
                        <h4 class="font-semibold text-gray-800 dark:text-white mb-3">Destination Map</h4>
                        <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-gray-700">
                            <Image
                                src={puertoJimenezMap}
                                alt="Map showing Puerto Jiménez and the Osa Peninsula"
                                width={1200}
                                class="w-full h-auto"
                            />
                        </div>
                    </div>
                </div>
            </div>

        </ContainerFluid>

        <!-- Maps Section -->
<!--         <ContainerFluid>
            <h2 class="text-3xl font-bold text-gray-800 dark:text-white mb-8 text-center">Route Maps</h2>
            <div class="grid md:grid-cols-2 gap-6">
                <a href="https://maps.app.goo.gl/HpHUj2pKGpr5RTVs5" 
                   target="_blank" 
                   rel="noopener noreferrer" 
                   class="group">
                    <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 border border-gray-100 dark:border-gray-700">
                        <div class="flex items-center space-x-4">
                            <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform">
                                🗺️
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold text-green-600 dark:text-green-400 group-hover:text-green-500 dark:group-hover:text-green-300 transition-colors">Coastal Route Map</h3>
                                <p class="text-gray-600 dark:text-gray-400">View the coastal route from San José to Rio Claro</p>
                            </div>
                        </div>
                    </div>
                </a>

                <a href="https://maps.app.goo.gl/xjzS5QsACZVSCTa58" 
                   target="_blank" 
                   rel="noopener noreferrer" 
                   class="group">
                    <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 border border-gray-100 dark:border-gray-700">
                        <div class="flex items-center space-x-4">
                            <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform">
                                🚢
                            </div>
                            <div>
                                <h3 class="text-xl font-semibold text-green-600 dark:text-green-400 group-hover:text-green-500 dark:group-hover:text-green-300 transition-colors">Rio Claro to Golfito Route</h3>
                                <p class="text-gray-600 dark:text-gray-400">View the route from Rio Claro to Golfito Ferry Terminal</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </ContainerFluid> -->
    </main>
</Layout>

<!-- Add this at the end of the main element, before the closing </main> tag -->
<!-- Map Modal -->
<div id="mapModal" class="fixed inset-0 bg-black bg-opacity-70 z-50 flex items-center justify-center hidden">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-4xl w-full mx-4 overflow-hidden">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
            <h3 id="modalTitle" class="text-xl font-bold text-gray-800 dark:text-white"></h3>
            <button onclick="closeMapModal()" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="p-0 h-[70vh]">
            <iframe id="mapFrame" src="" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </div>
</div>

</main>
</Layout>

<script is:inline>
    // Map modal functionality
    window.openMapModal = function(locationName, mapUrl) {
        document.getElementById('modalTitle').textContent = locationName;
        document.getElementById('mapFrame').src = mapUrl;
        document.getElementById('mapModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    window.closeMapModal = function() {
        document.getElementById('mapModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // Close modal when clicking outside of it
    document.getElementById('mapModal').addEventListener('click', function(event) {
        if (event.target === this) {
            closeMapModal();
        }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && !document.getElementById('mapModal').classList.contains('hidden')) {
            closeMapModal();
        }
    });
</script>
<style>
    @keyframes gradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    
    .animate-gradient {
        background-size: 200% 200%;
        animation: gradient 6s ease infinite;
    }
</style>
