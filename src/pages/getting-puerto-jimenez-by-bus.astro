---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import ContainerFluid from '../components/ContainerFluid.astro';
import Nav from '../components/Nav.astro';
import { Image } from 'astro:assets';
import puertoJimenezMap from '../assets/golfito_to_puerto_jimenez1.png';
---

<Layout title="Getting to Puerto Jimenez by Bus | Travel Guide">
    <main class="min-h-screen bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800">
        <Nav />
        
        <!-- Hero Section -->
        <ContainerFluid>
            <div class="text-center space-y-4 mb-12">
                <h1 class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-green-600 to-green-400 dark:from-green-400 dark:to-green-300 bg-clip-text text-transparent animate-gradient">
                    Getting to Puerto Jimenez by Bus
                </h1>
                <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
                    A comprehensive guide to reach Puerto Jimenez using public transportation
                </p>
            </div>
        </ContainerFluid>

        <!-- Step 1: From Airport -->
        <ContainerFluid>
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 mb-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                        <span class="text-2xl">1</span>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">From the Airport to San José</h2>
                </div>
                <div class="space-y-4 text-gray-700 dark:text-gray-300">
                    <div class="flex items-center space-x-3">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚌</span>
                        <span>Take a TUASA bus from the airport bus stop to San José.</span>
                        <a href="https://maps.app.goo.gl/YEqka8JYEoD7tVKg7"
                        target="_blank"
                        rel="noopener noreferrer">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                            View on Map
                        </span>
                    </a>
                    </div>
                    <div class="flex items-center space-x-3">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">💰</span>
                        <span>Cost: Approximately $6</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚏</span>
                        <span>Bus stop is located next to the airport</span>
                    </div>
                </div>
            </div>
        </ContainerFluid>

        <!-- Step 2: Options from San José -->
        <ContainerFluid>
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 mb-8">
                <div class="flex items-center space-x-4 mb-6">
                    <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                        <span class="text-2xl">2</span>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">From TUASA Terminal: Choose Your Route</h2>
                </div>

                <!-- Option 1 -->
                <div class="mb-8">
                    <h3 class="text-xl font-semibold text-green-600 dark:text-green-400 mb-4">Option 1: Direct Route</h3>
                    <div class="space-y-4 text-gray-700 dark:text-gray-300">
                        <div class="flex items-center space-x-3">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚕</span>
                            <span>Take a taxi to Transportes Blanco bus station (approximately $10)</span>
                            <a href="https://maps.app.goo.gl/fmrMM6jAbVWwLMnCA"
                            target="_blank"
                            rel="noopener noreferrer">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                                View on Map
                            </span>
                        </a>
                        </div>
                        <div class="flex items-center space-x-3">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">🚌</span>
                            <span>Take Transportes Blanco bus directly to Puerto Jiménez</span>
                            <a href="https://maps.app.goo.gl/AP6iJg5y4wuQDLyK7"
                            target="_blank"
                            rel="noopener noreferrer">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">
                                View on Map
                            </span>
                        </a>
                        </div>
                        <div class="flex items-center space-x-3">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">⏰</span>
                            <span>Departure time: 12:00 PM</span>
                        </div>
                        <div class="flex items-center space-x-3">
                            <span class="p-2 bg-green-100 dark:bg-green-900 rounded-full text-green-600 dark:text-green-400">💰</span>
