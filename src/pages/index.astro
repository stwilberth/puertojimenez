---
import Layout from '../layouts/Layout.astro';
import ContainerFluid from '../components/ContainerFluid.astro';
import Nav from '../components/Nav.astro';
import HubCard from '../components/HubCard.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { Image, type ImageMetadata } from 'astro:assets';
import puertoJimenezMap from '../assets/puerto_jimenez_map.jpg';

const artists = await getCollection('artists');
---

<Layout title="Welcome to Puerto Jimenez">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <main class="bg-slate-50 dark:bg-slate-950 min-h-screen">
        <Nav />
        
        <div class="relative py-24 overflow-hidden">
            <!-- Decorative Blobs -->
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-green-400/20 rounded-full blur-[120px] pointer-events-none"></div>
            <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-400/20 rounded-full blur-[120px] pointer-events-none"></div>

            <ContainerFluid>
                <section class="text-center space-y-8 relative z-10">
                    <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-slate-900 dark:text-white">
                        PUERTO <span class="text-green-500">JIMENEZ</span>
                    </h1>
                    <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto leading-relaxed font-medium flex items-center justify-center gap-3">
                        Your ultimate guide to the gateway of Corcovado National Park. 
                        <Icon name="fa6-solid:leaf" class="w-6 h-6 text-green-500 inline" />
                    </p>
                </section>
            </ContainerFluid>
        </div>
        
        <ContainerFluid>
            <div class="max-w-6xl mx-auto pb-24">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
                    <HubCard
                        href="/getting-puerto-jimenez"
                        title="Getting Here"
                        description="Plan your journey by air, land, or sea. All roads lead to paradise."
                        icon="fa6-regular:map"
                        iconColor="text-blue-300"
                        hoverTitle="group-hover:text-blue-300"
                        gradient="from-blue-900/40 to-cyan-700/20"
                        cta="Explore Routes"
                        featured
                        bgImage={puertoJimenezMap}
                        class="lg:col-span-3 lg:row-span-2"
                    />

                    <HubCard
                        href="/tours-and-activities"
                        title="Tours & Activities"
                        description="Guided wildlife treks and mangrove adventures."
                        icon="fa6-regular:compass"
                        iconColor="text-green-500"
                        hoverTitle="group-hover:text-green-500"
                        gradient="from-green-600/10 to-emerald-500/10"
                        class="lg:col-span-3 lg:row-span-2"
                    />

                    <!-- Artisans - Full width, prominent -->
                    <a href="/artisans" class="group lg:col-span-6">
                        <div class="relative h-80 md:h-96 bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden">
                            <!-- Background Slider -->
                            <div class="absolute inset-0 z-0">
                                <div class="swiper artisan-mini-swiper h-full w-full">
                                    <div class="swiper-wrapper">
                                        {artists.map(artist => (
                                            <div class="swiper-slide">
                                                {artist.data.image && (
                                                    <Image
                                                        src={artist.data.image as ImageMetadata}
                                                        alt={artist.data.name}
                                                        width={1200}
                                                        height={500}
                                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[3000ms]"
                                                    />
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>

                            <!-- Gradient overlay -->
                            <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-black/40 to-black/70 z-10"></div>

                            <!-- Content -->
                            <div class="absolute inset-0 z-20 p-6 md:p-8 flex flex-col justify-between">
                                <div>
                                    <div class="flex items-center gap-3 mb-4">
                                        <Icon name="fa6-solid:palette" class="w-6 h-6 text-orange-400" />
                                        <span class="text-orange-400 font-bold uppercase tracking-widest text-2xl md:text-4xl">Local Artisans</span>
                                    </div>
                                    <h2 class="text-xl md:text-2xl font-black text-white leading-tight max-w-xl">
                                        Authentic Jiménez<br/>Souvenirs
                                    </h2>
                                    <p class="text-white/60 mt-3 text-base md:text-lg max-w-md">
                                        Handcrafted in the Osa Peninsula. Every Friday at the Martina fair in Matapalo.
                                    </p>
                                </div>


                            </div>
                        </div>
                    </a>

                    <HubCard
                        href="/accommodation"
                        title="Stay"
                        description="Hotels, lodges & eco-cabinas"
                        icon="fa6-solid:bed"
                        iconColor="text-amber-500"
                        hoverTitle="group-hover:text-amber-500"
                        gradient="from-amber-600/10 to-yellow-500/10"
                        class="lg:col-span-3 h-48"
                    />

                    <HubCard
                        href="/restaurants"
                        title="Dine"
                        description="Restaurants & local sodas"
                        icon="fa6-solid:utensils"
                        iconColor="text-red-500"
                        hoverTitle="group-hover:text-red-500"
                        gradient="from-red-600/10 to-rose-500/10"
                        class="lg:col-span-3 h-48"
                    />
                </div>
            </div>
        </ContainerFluid>
    </main>
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script is:inline>
        new Swiper('.artisan-mini-swiper', {
            effect: 'fade',
            fadeEffect: {
                crossFade: true
            },
            autoplay: {
                delay: 3000,
                disableOnInteraction: false,
            },
            loop: true,
            speed: 1000,
        });
    </script>
</Layout>

<style>
    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
        100% { transform: translateY(0px); }
    }
    
    .floating {
        animation: float 4s ease-in-out infinite;
    }
</style>

