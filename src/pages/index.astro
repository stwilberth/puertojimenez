---
import Layout from '../layouts/Layout.astro';
import ContainerFluid from '../components/ContainerFluid.astro';
import Nav from '../components/Nav.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { Image, type ImageMetadata } from 'astro:assets';

const artists = await getCollection('artists');
---

<Layout title="Welcome to Puerto Jimenez">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <main class="bg-slate-50 dark:bg-slate-950 min-h-screen">
        <Nav />
        
        <div class="relative py-24 overflow-hidden">
            <!-- Decorative Blobs -->
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-green-400/20 rounded-full blur-[120px] pointer-events-none"></div>
            <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-400/20 rounded-full blur-[120px] pointer-events-none"></div>

            <ContainerFluid>
                <section class="text-center space-y-8 relative z-10">
                    <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-slate-900 dark:text-white">
                        PUERTO <span class="text-green-500">JIMENEZ</span>
                    </h1>
                    <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto leading-relaxed font-medium flex items-center justify-center gap-3">
                        Your ultimate guide to the gateway of Corcovado National Park. 
                        <Icon name="fa6-solid:leaf" class="w-6 h-6 text-green-500 inline" />
                    </p>
                </section>
            </ContainerFluid>
        </div>
        
        <ContainerFluid>
            <div class="max-w-6xl mx-auto pb-24">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
                    <!-- Getting Here Card - Large -->
                    <a href="/getting-puerto-jimenez" class="group lg:col-span-4 lg:row-span-2">
                        <div class="relative h-full bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 dark:border-slate-800">
                            <div class="absolute inset-0 bg-gradient-to-br from-blue-600/10 to-cyan-500/10 group-hover:opacity-100 transition-opacity"></div>
                            <div class="p-10 flex flex-col h-full relative z-10">
                                <div class="flex items-center gap-6 mb-4">
                                    <div class="text-blue-500 group-hover:scale-110 transition-transform duration-500">
                                        <Icon name="fa6-regular:map" class="w-12 h-12" />
                                    </div>
                                    <h2 class="text-4xl font-black text-slate-900 dark:text-white group-hover:text-blue-500 transition-colors">Getting Here</h2>
                                </div>
                                <p class="text-xl text-slate-600 dark:text-slate-400">Plan your journey by air, land, or sea. All roads lead to paradise.</p>
                                <div class="mt-auto pt-10">
                                    <span class="inline-flex items-center text-blue-500 font-bold tracking-widest uppercase text-sm">
                                        Explore Routes 
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- Tours & Activities - Vertical -->
                    <a href="/tours-and-activities" class="group lg:col-span-2 lg:row-span-2">
                        <div class="relative h-full bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 dark:border-slate-800">
                            <div class="absolute inset-0 bg-gradient-to-br from-green-600/10 to-emerald-500/10 group-hover:opacity-100 transition-opacity"></div>
                            <div class="p-10 flex flex-col h-full relative z-10">
                                <div class="flex items-center gap-4 mb-3">
                                    <div class="text-green-500 group-hover:scale-110 transition-transform duration-500">
                                        <Icon name="fa6-regular:compass" class="w-10 h-10" />
                                    </div>
                                    <h2 class="text-3xl font-black text-slate-900 dark:text-white">Tours & Activities</h2>
                                </div>
                                <p class="text-slate-600 dark:text-slate-400">Guided wildlife treks and mangrove adventures.</p>
                            </div>
                        </div>
                    </a>

                    <!-- Artisans - Full width, prominent -->
                    <a href="/artisans" class="group lg:col-span-6">
                        <div class="relative h-80 md:h-96 bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden">
                            <!-- Background Slider -->
                            <div class="absolute inset-0 z-0">
                                <div class="swiper artisan-mini-swiper h-full w-full">
                                    <div class="swiper-wrapper">
                                        {artists.map(artist => (
                                            <div class="swiper-slide">
                                                {artist.data.image && (
                                                    <Image
                                                        src={artist.data.image as ImageMetadata}
                                                        alt={artist.data.name}
                                                        width={1200}
                                                        height={500}
                                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[3000ms]"
                                                    />
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>

                            <!-- Gradient overlay -->
                            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-black/10 z-10"></div>

                            <!-- Content -->
                            <div class="absolute inset-0 z-20 p-8 md:p-12 flex flex-col justify-between">
                                <div>
                                    <div class="flex items-center gap-3 mb-4">
                                        <Icon name="fa6-solid:palette" class="w-6 h-6 text-orange-400" />
                                        <span class="text-orange-400 font-bold uppercase tracking-widest text-xs">Local Artisans</span>
                                    </div>
                                    <h2 class="text-4xl md:text-5xl font-black text-white leading-tight max-w-xl">
                                        Authentic Jiménez<br/>Souvenirs
                                    </h2>
                                    <p class="text-white/60 mt-3 text-base md:text-lg max-w-md">
                                        Handcrafted in the Osa Peninsula. Every Friday at the Martínez fair in Matapalo.
                                    </p>
                                </div>

                                <!-- Artist name chips -->
                                <div class="flex flex-wrap gap-3 items-center">
                                    {artists.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)).map(artist => (
                                        <span class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full border border-white/20 text-white text-sm font-semibold">
                                            {artist.data.name.split(' ')[0]}
                                        </span>
                                    ))}
                                    <span class="text-white/50 text-sm font-bold group-hover:text-orange-400 transition-colors flex items-center gap-1">
                                        Meet them all
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- Accommodation -->
                    <a href="/accommodation" class="group lg:col-span-3">
                        <div class="relative h-48 bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 dark:border-slate-800">
                            <div class="absolute inset-0 bg-gradient-to-br from-amber-600/10 to-yellow-500/10 group-hover:opacity-100 transition-opacity"></div>
                            <div class="p-8 flex flex-col h-full relative z-10 justify-between">
                                <div class="text-amber-500 group-hover:scale-110 transition-transform duration-500 w-fit">
                                    <Icon name="fa6-solid:bed" class="w-8 h-8" />
                                </div>
                                <div>
                                    <h2 class="text-2xl font-black text-slate-900 dark:text-white">Stay</h2>
                                    <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Hotels, lodges & eco-cabinas</p>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- Restaurants -->
                    <a href="/restaurants" class="group lg:col-span-3">
                        <div class="relative h-48 bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 dark:border-slate-800">
                            <div class="absolute inset-0 bg-gradient-to-br from-red-600/10 to-rose-500/10 group-hover:opacity-100 transition-opacity"></div>
                            <div class="p-8 flex flex-col h-full relative z-10 justify-between">
                                <div class="text-red-500 group-hover:scale-110 transition-transform duration-500 w-fit">
                                    <Icon name="fa6-solid:utensils" class="w-8 h-8" />
                                </div>
                                <div>
                                    <h2 class="text-2xl font-black text-slate-900 dark:text-white">Dine</h2>
                                    <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Restaurants & local sodas</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </ContainerFluid>
    </main>
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script is:inline>
        new Swiper('.artisan-mini-swiper', {
            effect: 'fade',
            fadeEffect: {
                crossFade: true
            },
            autoplay: {
                delay: 3000,
                disableOnInteraction: false,
            },
            loop: true,
            speed: 1000,
        });
    </script>
</Layout>

<style>
    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
        100% { transform: translateY(0px); }
    }
    
    .floating {
        animation: float 4s ease-in-out infinite;
    }
</style>

